{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "debug",
      "displayName": "Debug Mode (Ninja)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release Mode (Ninja)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "app-release",
      "displayName": "macOS App Release (Ninja)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-app",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "web-release",
      "displayName": "Web Release (Emscripten)",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-web",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSCRIPTEN}/cmake/Modules/Platform/Emscripten.cmake",
        "PLATFORM": "Web"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "app-release",
      "configurePreset": "app-release"
    },
    {
      "name": "web-release",
      "configurePreset": "web-release"
    }
  ]
}
